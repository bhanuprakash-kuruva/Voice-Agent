# ============================================
# VOICE RAG AGENT - ENVIRONMENT CONFIGURATION
# ============================================

# --------------------------------------------
# RAG STORAGE & PATHS
# --------------------------------------------
WORKING_DIR=./rag_storage
DOCUMENT_PATH=./data/document.pdf
OUTPUT_DIR=./output

# --------------------------------------------
# LLM CONFIGURATION
# --------------------------------------------
LLM_BINDING=openai
LLM_BINDING_HOST=http://localhost:11434/v1
LLM_MODEL=phi3
LLM_MAX_TOKENS=128
OPENAI_API_KEY=ollama

# Ollama LLM specific settings
OLLAMA_LLM_NUM_CTX=1024
OLLAMA_LLM_NUM_PREDICT=128
OLLAMA_LLM_TEMPERATURE=0.3

# LLM Timeouts (seconds)
LLM_TIMEOUT=600
RAG_TIMEOUT=900

# --------------------------------------------
# EMBEDDING CONFIGURATION
# --------------------------------------------
EMBEDDING_BINDING=ollama
EMBEDDING_BINDING_HOST=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# --------------------------------------------
# CACHE CONFIGURATION
# --------------------------------------------
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL=3600
LLM_CACHE_MAX_SIZE=1000
EMBEDDING_CACHE_ENABLED=true

# --------------------------------------------
# RAG QUERY CONFIGURATION
# --------------------------------------------
TOP_K=5
COSINE_THRESHOLD=0.2
RAG_MODE=local  # Options: local, global, hybrid, naive
ENABLE_RERANK=false  # Set to false for faster responses

# --------------------------------------------
# CHUNKING CONFIGURATION
# --------------------------------------------
CHUNK_SIZE=50
CHUNK_OVERLAP_SIZE=20
CHUNK_MAX_TOKENS=150

# --------------------------------------------
# VOICE / STT CONFIGURATION
# --------------------------------------------
WHISPER_MODEL=small  # Options: tiny, base, small, medium, large
WHISPER_DEVICE=cpu   # Options: cpu, cuda
WHISPER_COMPUTE_TYPE=int8  # Options: int8, float16, float32
SAMPLE_RATE=16000
AUDIO_DURATION=5

# --------------------------------------------
# VOICE / TTS CONFIGURATION
# --------------------------------------------
TTS_RATE=170
TTS_VOLUME=1.0
TTS_VOICE_ID=  # Leave empty for system default

# --------------------------------------------
# SESSION MANAGEMENT
# --------------------------------------------
SESSION_TIMEOUT=3600  # Session timeout in seconds (1 hour)
MAX_RETRIES=3

# --------------------------------------------
# OBSERVABILITY & METRICS
# --------------------------------------------
# Metrics server port
METRICS_PORT=8000

# OpenTelemetry tracing
OTLP_ENDPOINT=localhost:30417
ENABLE_CONSOLE_EXPORTER=false
SAMPLING_RATE=1.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=./voice-rag.log
ENABLE_CONSOLE_LOGS=true

# --------------------------------------------
# APPLICATION ENVIRONMENT
# --------------------------------------------
ENVIRONMENT=development  # Options: development, staging, production
SERVICE_VERSION=2.0
USER_ID=  # Optional: set for authenticated user

# --------------------------------------------
# PERFORMANCE TUNING
# --------------------------------------------
MAX_ASYNC=1
CONCURRENT_REQUESTS_LIMIT=5

# --------------------------------------------
# DATABASE (Optional - if using external storage)
# --------------------------------------------
# VECTOR_DB_PATH=./vectordb
# REDIS_URL=redis://localhost:6379
# POSTGRES_URL=postgresql://user:pass@localhost:5432/rag

# --------------------------------------------
# FEATURE FLAGS
# --------------------------------------------
ENABLE_TTS=true
ENABLE_STT=true
ENABLE_METRICS=true
ENABLE_TRACING=true