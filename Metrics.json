{
  "dashboard": {
    "title": "Voice RAG Service Monitoring",
    "description": "Comprehensive monitoring dashboard for Voice RAG Agent",
    "tags": ["voice-rag", "prometheus", "performance"],
    "timezone": "browser",
    "panels": [
      {
        "title": "Service Overview",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "voice_rag_service_info{name=\"voice-rag-agent\"}",
            "format": "table"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "justifyMode": "auto"
        }
      },
      {
        "title": "Active Sessions",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
        "targets": [
          {
            "expr": "active_sessions",
            "format": "time_series"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "none"
        }
      },
      {
        "title": "Active Requests",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
        "targets": [
          {
            "expr": "rag_active_requests",
            "format": "time_series"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "none"
        }
      },
      {
        "title": "Concurrent Requests",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "concurrent_requests",
            "format": "time_series"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "none"
        }
      },
      {
        "title": "Pipeline Latency Distribution",
        "type": "histogram",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(rag_pipeline_latency_seconds_bucket[5m])) by (le))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(rag_pipeline_latency_seconds_bucket[5m])) by (le))",
            "legendFormat": "p99"
          },
          {
            "expr": "rate(rag_pipeline_latency_seconds_sum[5m]) / rate(rag_pipeline_latency_seconds_count[5m])",
            "legendFormat": "avg"
          }
        ],
        "options": {
          "orientation": "auto"
        }
      },
      {
        "title": "Stage-wise Latency Breakdown",
        "type": "barchart",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "rate(audio_record_latency_seconds_sum[5m]) / rate(audio_record_latency_seconds_count[5m])",
            "legendFormat": "Audio Record"
          },
          {
            "expr": "rate(stt_latency_seconds_sum[5m]) / rate(stt_latency_seconds_count[5m])",
            "legendFormat": "STT"
          },
          {
            "expr": "rate(llm_latency_seconds_sum[5m]) / rate(llm_latency_seconds_count[5m])",
            "legendFormat": "LLM"
          },
          {
            "expr": "rate(tts_latency_seconds_sum[5m]) / rate(tts_latency_seconds_count[5m])",
            "legendFormat": "TTS"
          }
        ],
        "options": {
          "orientation": "vertical"
        }
      },
      {
        "title": "GC Collections by Generation",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 8, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "rate(python_gc_collections_total{generation=\"0\"}[5m])",
            "legendFormat": "Gen 0"
          },
          {
            "expr": "rate(python_gc_collections_total{generation=\"1\"}[5m])",
            "legendFormat": "Gen 1"
          },
          {
            "expr": "rate(python_gc_collections_total{generation=\"2\"}[5m])",
            "legendFormat": "Gen 2"
          }
        ]
      },
      {
        "title": "GC Objects Collected",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 8, "x": 8, "y": 12},
        "targets": [
          {
            "expr": "rate(python_gc_objects_collected_total{generation=\"0\"}[5m])",
            "legendFormat": "Gen 0"
          },
          {
            "expr": "rate(python_gc_objects_collected_total{generation=\"1\"}[5m])",
            "legendFormat": "Gen 1"
          },
          {
            "expr": "rate(python_gc_objects_collected_total{generation=\"2\"}[5m])",
            "legendFormat": "Gen 2"
          }
        ]
      },
      {
        "title": "LLM Token Usage",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 8, "x": 16, "y": 12},
        "targets": [
          {
            "expr": "rate(llm_prompt_tokens_sum[5m]) / rate(llm_prompt_tokens_count[5m])",
            "legendFormat": "Avg Prompt Tokens"
          },
          {
            "expr": "rate(llm_completion_tokens_sum[5m]) / rate(llm_completion_tokens_count[5m])",
            "legendFormat": "Avg Completion Tokens"
          },
          {
            "expr": "rate(llm_total_tokens_sum[5m]) / rate(llm_total_tokens_count[5m])",
            "legendFormat": "Avg Total Tokens"
          }
        ]
      },
      {
        "title": "LLM Token Speed",
        "type": "gauge",
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 18},
        "targets": [
          {
            "expr": "rate(llm_tokens_per_second_sum[5m]) / rate(llm_tokens_per_second_count[5m])",
            "format": "time_series"
          }
        ],
        "options": {
          "showThresholdLabels": true,
          "showThresholdMarkers": true,
          "thresholds": [
            {"color": "green", "value": null},
            {"color": "orange", "value": 20},
            {"color": "red", "value": 10}
          ]
        }
      },
      {
        "title": "Cache Performance",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 6, "y": 18},
        "targets": [
          {
            "expr": "llm_cache_hits_total / (llm_cache_hits_total + llm_cache_misses_total) * 100",
            "format": "time_series"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "unit": "percent"
        }
      },
      {
        "title": "LLM Request Status",
        "type": "piechart",
        "gridPos": {"h": 6, "w": 6, "x": 12, "y": 18},
        "targets": [
          {
            "expr": "sum(llm_requests_total{status=\"success\"})",
            "legendFormat": "Success"
          },
          {
            "expr": "sum(llm_requests_total{status=\"pending\"})",
            "legendFormat": "Pending"
          }
        ],
        "options": {
          "pieType": "pie",
          "displayLabels": ["name", "percent"]
        }
      },
      {
        "title": "Query & Response Length",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 6, "x": 18, "y": 18},
        "targets": [
          {
            "expr": "rate(rag_query_length_chars_sum[5m]) / rate(rag_query_length_chars_count[5m])",
            "legendFormat": "Query Length"
          },
          {
            "expr": "rate(rag_response_length_chars_sum[5m]) / rate(rag_response_length_chars_count[5m])",
            "legendFormat": "Response Length"
          }
        ]
      },
      {
        "title": "CPU Usage by Stage",
        "type": "timeseries",
        "gridPos": {"h": 7, "w": 12, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "rate(rag_stage_cpu_usage_seconds_sum{stage=\"audio_capture\"}[5m]) / rate(rag_stage_cpu_usage_seconds_count{stage=\"audio_capture\"}[5m])",
            "legendFormat": "Audio Capture"
          },
          {
            "expr": "rate(rag_stage_cpu_usage_seconds_sum{stage=\"stt\"}[5m]) / rate(rag_stage_cpu_usage_seconds_count{stage=\"stt\"}[5m])",
            "legendFormat": "STT"
          },
          {
            "expr": "rate(rag_stage_cpu_usage_seconds_sum{stage=\"llm_generation\"}[5m]) / rate(rag_stage_cpu_usage_seconds_count{stage=\"llm_generation\"}[5m])",
            "legendFormat": "LLM"
          },
          {
            "expr": "rate(rag_stage_cpu_usage_seconds_sum{stage=\"embedding\"}[5m]) / rate(rag_stage_cpu_usage_seconds_count{stage=\"embedding\"}[5m])",
            "legendFormat": "Embedding"
          },
          {
            "expr": "rate(rag_stage_cpu_usage_seconds_sum{stage=\"tts\"}[5m]) / rate(rag_stage_cpu_usage_seconds_count{stage=\"tts\"}[5m])",
            "legendFormat": "TTS"
          }
        ]
      },
      {
        "title": "Memory Usage by Stage",
        "type": "barchart",
        "gridPos": {"h": 7, "w": 12, "x": 12, "y": 24},
        "targets": [
          {
            "expr": "rate(rag_stage_memory_usage_mb_sum{stage=\"audio_capture\"}[5m]) / rate(rag_stage_memory_usage_mb_count{stage=\"audio_capture\"}[5m])",
            "legendFormat": "Audio Capture"
          },
          {
            "expr": "rate(rag_stage_memory_usage_mb_sum{stage=\"stt\"}[5m]) / rate(rag_stage_memory_usage_mb_count{stage=\"stt\"}[5m])",
            "legendFormat": "STT"
          },
          {
            "expr": "rate(rag_stage_memory_usage_mb_sum{stage=\"llm_generation\"}[5m]) / rate(rag_stage_memory_usage_mb_count{stage=\"llm_generation\"}[5m])",
            "legendFormat": "LLM"
          },
          {
            "expr": "rate(rag_stage_memory_usage_mb_sum{stage=\"embedding\"}[5m]) / rate(rag_stage_memory_usage_mb_count{stage=\"embedding\"}[5m])",
            "legendFormat": "Embedding"
          },
          {
            "expr": "rate(rag_stage_memory_usage_mb_sum{stage=\"tts\"}[5m]) / rate(rag_stage_memory_usage_mb_count{stage=\"tts\"}[5m])",
            "legendFormat": "TTS"
          }
        ]
      },
      {
        "title": "Embedding Performance",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 8, "x": 0, "y": 31},
        "targets": [
          {
            "expr": "rate(embedding_latency_seconds_sum[5m]) / rate(embedding_latency_seconds_count[5m])",
            "legendFormat": "Avg Latency"
          },
          {
            "expr": "histogram_quantile(0.95, rate(embedding_latency_seconds_bucket[5m]))",
            "legendFormat": "p95 Latency"
          }
        ]
      },
      {
        "title": "STT Confidence Score",
        "type": "gauge",
        "gridPos": {"h": 6, "w": 8, "x": 8, "y": 31},
        "targets": [
          {
            "expr": "stt_confidence_score_sum / stt_confidence_score_count",
            "format": "time_series"
          }
        ],
        "options": {
          "min": 0,
          "max": 1,
          "thresholds": [
            {"color": "red", "value": null},
            {"color": "orange", "value": 0.5},
            {"color": "green", "value": 0.8}
          ]
        }
      },
      {
        "title": "Audio Input Duration",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 8, "x": 16, "y": 31},
        "targets": [
          {
            "expr": "rate(audio_input_duration_seconds_sum[5m]) / rate(audio_input_duration_seconds_count[5m])",
            "legendFormat": "Avg Duration"
          },
          {
            "expr": "histogram_quantile(0.95, rate(audio_input_duration_seconds_bucket[5m]))",
            "legendFormat": "p95 Duration"
          }
        ]
      },
      {
        "title": "Request Rate by User",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 37},
        "targets": [
          {
            "expr": "rate(requests_per_user_total[5m])",
            "legendFormat": "{{user_type}} - {{user_id}}"
          }
        ]
      },
      {
        "title": "Error Rates",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 37},
        "targets": [
          {
            "expr": "rate(rag_errors_total[5m])",
            "legendFormat": "RAG Errors"
          },
          {
            "expr": "rate(stt_errors_total[5m])",
            "legendFormat": "STT Errors"
          },
          {
            "expr": "rate(tts_errors_total[5m])",
            "legendFormat": "TTS Errors"
          }
        ]
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "refresh": "30s",
    "schemaVersion": 36,
    "version": 1,
    "links": []
  }
}